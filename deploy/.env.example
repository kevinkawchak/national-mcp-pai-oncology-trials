# National MCP-PAI Oncology Trials — Environment Configuration
# Copy to .env and edit values for your deployment

# Storage backend: memory, sqlite, postgresql
TRIALMCP_STORAGE_BACKEND=memory

# SQLite DSN (only for sqlite backend)
TRIALMCP_STORAGE_DSN=trialmcp.db

# PostgreSQL DSN (only for postgresql backend)
# TRIALMCP_STORAGE_DSN=postgresql://user:password@localhost:5432/trialmcp

# Log level: DEBUG, INFO, WARNING, ERROR
TRIALMCP_LOG_LEVEL=INFO

# Server host/port (override per-server as needed)
TRIALMCP_HOST=0.0.0.0
TRIALMCP_PORT=8000

# HMAC key for FHIR de-identification pseudonymization
TRIALMCP_HMAC_KEY=change-this-to-a-secure-random-key

# Config file path (optional)
# TRIALMCP_CONFIG_FILE=/etc/trialmcp/config.yaml
