{
  "name": "@trialmcp/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the National MCP-PAI Oncology Trials network. Provides typed clients for AuthZ, FHIR, DICOM, Ledger, and Provenance MCP servers with connection management, retry logic, circuit breaking, and audit logging.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "jest --config jest.config.js",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:watch": "jest --config jest.config.js --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "oncology",
    "clinical-trials",
    "physical-ai",
    "fhir",
    "dicom",
    "audit",
    "provenance",
    "rbac"
  ],
  "author": "National MCP-PAI Oncology Trials Consortium",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/national-mcp-pai-oncology-trials/national-mcp-pai-oncology-trials"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {},
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "require": "./dist/client.js"
    },
    "./authz": {
      "types": "./dist/authz.d.ts",
      "require": "./dist/authz.js"
    },
    "./fhir": {
      "types": "./dist/fhir.d.ts",
      "require": "./dist/fhir.js"
    },
    "./dicom": {
      "types": "./dist/dicom.d.ts",
      "require": "./dist/dicom.js"
    },
    "./ledger": {
      "types": "./dist/ledger.d.ts",
      "require": "./dist/ledger.js"
    },
    "./provenance": {
      "types": "./dist/provenance.d.ts",
      "require": "./dist/provenance.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "require": "./dist/errors.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "require": "./dist/middleware/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "require": "./dist/models/index.js"
    }
  }
}
